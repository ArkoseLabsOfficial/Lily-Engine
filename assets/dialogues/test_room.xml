<!DOCTYPE lily-engine-dialog>
<dialogues>
    <dialog id="start">
        <entry leftChar="lacie/blank2" name="Lacie" text="You're back!" if="chat" />
        
        <entry leftChar="lacie/blank3" name="Lacie" text="dialogs.intro" hasSelection="true">
            <selections>
                <item id="var_test" text="dialogs.selection.variables" selectionConfirmed="path_var_test" if="has_item" />
                <item id="chat" text="dialogs.selection.chat" selectionConfirmed="path_chat" />
                <item id="leave" text="dialogs.selection.leave" selectionConfirmed="path_leave" />
                <item id="bruh" text="Do You Speak English?" selectionConfirmed="path_kurdish" />
            </selections>
        </entry>
    </dialog>

    <dialog id="path_var_test">
        <entry leftChar="lacie/blank7" rightChar="aoi/annoyed" name="Lacie" text="dialogs.variables.success" return="start" />
    </dialog>

    <dialog id="path_kurdish">
        <entry leftChar="lacie/blank5" name="Lacie" text="Do you speak English?" />
        <entry leftChar="lacie/blank4" rightChar="aoi/coy" name="Aoi" text="Yes." />
        <entry leftChar="lacie/shadow5" rightChar="aoi/coy" name="Lacie" text="Heeeh, Eeee..." />
        <entry leftChar="lacie/sigh" rightChar="aoi/coy" name="Lacie" text="Ben no speak english." />
        <entry leftChar="lacie/hide2" rightChar="aoi/coy" name="Lacie" text="Ahaa..., Bu speak english." />
        <entry leftChar="lacie/reflective4" rightChar="aoi/coy" name="Lacie" text="Okay?" />
        <entry leftChar="lacie/reflective5" rightChar="aoi/crazy" name="Aoi" text="Okay." />
        <entry leftChar="lacie/sigh" rightChar="aoi/melt2" name="Lacie" text="Heeehh..." />
        <entry leftChar="lacie/thinking3" rightChar="aoi/melt2" name="Lacie" text="Usta her gün bana 10 kelime ingilizce öğretsen ben bu işi çözerim." return="start"/>
    </dialog>

    <dialog id="path_chat">
        <entry leftChar="lacie/blank2" name="Kukla" text="dialogs.chat.1" />
        <entry leftChar="smile" name="Lacie" text="dialogs.chat.2" return="start" />
    </dialog>

    <dialog id="path_leave">
        <entry leftChar="neutral" name="Lacie" text="dialogs.leave" setFlag="has_left_room" closeTheBox="true" />
    </dialog>
</dialogues>